# Django
SECRET_KEY=your-secret-key-min-50-chars-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Docker Compose
POSTGRES_USER=shop
POSTGRES_PASSWORD=shop
POSTGRES_DB=shop_db

# Redis (кэш и rate limiting). В Docker задаётся автоматически.
# REDIS_URL=redis://redis:6379/0

# Продакшен
# DJANGO_SETTINGS_MODULE=config.settings.production
# ALLOWED_HOSTS=yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# SSL/Let's Encrypt
# ADMIN_EMAIL=admin@yourdomain.com
# SSL_STAGING=0  # 0 = боевой сертификат, 1 = тестовый

# Email 
EMAIL_HOST=mail.yourdomain.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@yourdomain.com
EMAIL_HOST_PASSWORD=noreply_password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
SERVER_EMAIL=noreply@yourdomain.com

# Google reCAPTCHA (для форм)
RECAPTCHA_PUBLIC_KEY=your-recaptcha-site-key
RECAPTCHA_PRIVATE_KEY=your-recaptcha-secret-key

# Срок действия ссылки активации аккаунта (в секундах, по умолчанию 24 часа)
ACCOUNT_ACTIVATION_TIMEOUT=86400

# Копия писем о заказах (при оформлении заказа) на этот адрес
ORDER_NOTIFICATION_EMAIL=shop@yourdomain.com

# СДЭК API
CDEK_ACCOUNT=
CDEK_SECURE=
CDEK_TEST=1
CDEK_FROM_CITY_CODE=137
CDEK_FROM_CITY_NAME=Санкт-Петербург
CDEK_FROM_ADDRESS=
CDEK_FROM_PVZ_CODE=
CDEK_SENDER_NAME=
CDEK_SENDER_PHONE=
CDEK_SENDER_COMPANY=
YANDEX_MAPS_API_KEY=

# T‑Банк (интернет-эквайринг)
TBANK_TERMINAL_KEY=
TBANK_PASSWORD=
TBANK_API_BASE_URL=https://securepay.tinkoff.ru
TBANK_TIMEOUT=15
# Фискализация (чеки 54-ФЗ, Т-Чеки)
# Система налогообложения: osn, usn_income, usn_income_outcome, esn, patent
TBANK_TAXATION=usn_income
# Ставка НДС на товары: none, vat0, vat10, vat20
TBANK_VAT_RATE=none
# Ставка НДС на доставку (обычно та же, что и на товары)
TBANK_DELIVERY_VAT_RATE=none
